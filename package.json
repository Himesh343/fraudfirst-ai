{
  "name": "fraudfirst",
  "version": "1.0.0",
  "private": true,
  "description": "FraudFirst - AI Cyber-Fraud Emergency Assistant",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "npm run dev --workspace client",
    "server": "npm run dev --workspace server",
    "build": "npm run build --workspace client && npm run lint --workspace server",
    "lint": "npm run lint --workspace client && npm run lint --workspace server",
    "test": "npm run test --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
